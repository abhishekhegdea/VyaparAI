              "host": ["{{base_url}}"],
              "path": ["cart", "remove", "{{cart_id}}"]
            },
            "description": "Remove an item from the cart"
          },
          "response": []
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/clear",
              "host": ["{{base_url}}"],
              "path": ["cart", "clear"]
